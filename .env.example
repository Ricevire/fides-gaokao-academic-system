NODE_ENV=production
APP_NAME=fides-gaokao-academic-system
APP_VERSION=1.0.0
PORT=3000
BODY_LIMIT=2mb
TRUST_PROXY=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fides_app
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=fides_gaokao
DB_AUTO_CREATE=false
DB_CONNECTION_LIMIT=20
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=8h
CORS_ORIGINS=https://your-domain.example
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
ADMIN_INITIAL_PASSWORD=replace-with-first-admin-password
AUDIT_EVENT_LOG_ENABLED=true
AUDIT_SIEM_WEBHOOK_URL=
AUDIT_SIEM_WEBHOOK_TOKEN=
AUDIT_ALERTS_ENABLED=true
AUDIT_ALERT_WEBHOOK_URL=
AUDIT_ALERT_WEBHOOK_TOKEN=
AUDIT_FAILED_LOGIN_WINDOW_MS=900000
AUDIT_FAILED_LOGIN_THRESHOLD=5
AUDIT_ACCOUNT_RESET_WINDOW_MS=900000
AUDIT_ACCOUNT_RESET_THRESHOLD=3
AUDIT_NEW_IP_LOOKBACK_DAYS=90
AUDIT_SLOW_API_ENABLED=true
AUDIT_SLOW_API_THRESHOLD_MS=1500
OIDC_ENABLED=false
OIDC_PROVIDER_CODE=oidc
OIDC_PROVIDER_NAME=学校统一身份认证
OIDC_TENANT_ID=1
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email phone
OIDC_TOKEN_AUTH_METHOD=client_secret_post
OIDC_SUBJECT_CLAIM=sub
OIDC_USERNAME_CLAIM=preferred_username
OIDC_DISPLAY_NAME_CLAIM=name
OIDC_EMAIL_CLAIM=email
OIDC_PHONE_CLAIM=phone_number
OIDC_AUTO_LINK_BY_USERNAME=true
SMS_ENABLED=false
SMS_PROVIDER=log
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
SMS_ACCOUNT_NOTIFY_ENABLED=false
LOG_LEVEL=info
